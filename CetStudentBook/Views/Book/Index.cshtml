@model IEnumerable<CetStudentBook.Models.Book>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<h1>Students</h1>
<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>   
    </p>
       <table class="table table-hover">
        <thead>
            <tr>
                <th>
                    ID
                    
                </th>
                <th>
                    Name
                    
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
        {
            <tr>
                <td>
                    @item.Id
                </td>
                <td>
                    @item.Name
                </td>
                <td>
                    @item.Author
                </td>
                <td>
                    @item.PublishDate.ToShortDateString()
                </td>
                <td>
                    @item.PageCount
                </td>
                    @if (item.IsSecondHand) // https://learn.microsoft.com/en-us/aspnet/core/mvc/views/razor?view=aspnetcore-10.0#control-structures
                    {
                        <td>Second Hand</td>
                    }
                    else
                    {
                        <td>Firsthand</td>
                    }
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Edit</a>
                </td>
            </tr>
        }
        </tbody>    
        </table>


                