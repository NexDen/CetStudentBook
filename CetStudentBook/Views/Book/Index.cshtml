@model IEnumerable<CetStudentBook.Models.Book>

<h1>Books</h1>
<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>   
    </p>
       <table class="table table-hover">
        <thead>
            <tr>
                <th>
                    ID
                    
                </th>
                <th>
                    Name
                    
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
        {
            <tr>
                <td>
                    @item.Id
                </td>
                <td>
                    @item.Name
                </td>
                <td>
                    @item.Author
                </td>
                <td>
                    @item.PublishDate.ToShortDateString()
                </td>
                <td>
                    @item.PageCount
                </td>
                    @if (item.IsSecondHand) // https://learn.microsoft.com/en-us/aspnet/core/mvc/views/razor?view=aspnetcore-10.0#control-structures
                    {
                        <td>Second Hand</td>
                    }
                    else
                    {
                        <td>Firsthand</td>
                    }
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Edit</a>
                </td>
                <td> <!-- AI ATTRIBUTION: https://chatgpt.com/share/69a4c584-3c5c-8012-8508-24417df48fff -->
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this item?')"> 
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
        </tbody>    
        </table>


                